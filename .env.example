# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret for signing session tokens
JWT_SECRET="super-secret-key-change-me"

# GMAIL API CONFIGURATION (For Automated UPI Verification)
# Client ID and Secret from Google Cloud Console
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
# Refresh Token with 'https://www.googleapis.com/auth/gmail.readonly' scope
GMAIL_REFRESH_TOKEN=""

# BANK CONFIGURATION
# Email address of the bank that sends transaction alerts
TRUSTED_BANK_SENDER="alerts@hdfcbank.net"
# Trusted domain for sender validation
TRUSTED_BANK_DOMAIN="hdfcbank.net"

# GOOGLE MAPS PLATFORM (For Geolocation & Geocoding)
GOOGLE_MAPS_PLATFORM_KEY=""

# FIREBASE CONFIGURATION (FOR PRODUCTION/STAGING)
# JSON string of the Firebase Service Account Key
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'
# Firebase Project ID
FIREBASE_PROJECT_ID=""
# Firebase API Key
VITE_FIREBASE_API_KEY=""
# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=""
# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=""
# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=""
# Firebase App ID
VITE_FIREBASE_APP_ID=""
# Firestore Database ID
VITE_FIRESTORE_DATABASE_ID=""
# Session Secret for cookie encryption
SESSION_SECRET="super-secret-key-change-me"
# Firebase Realtime Database URL (optional, defaults to https://<projectId>-default-rtdb.firebaseio.com)
FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.firebaseio.com"
# FIRESTORE_BACKUP_BUCKET="your-gcs-bucket-name"
FIRESTORE_BACKUP_BUCKET=""
