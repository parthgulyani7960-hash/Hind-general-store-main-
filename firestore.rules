rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hardened Global Defaults
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Products & Categories - Publicly readable for the shopfront
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{categoryId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    match /product_variants/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- Settings & Delivery ---
    match /settings/{key} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    match /delivery_areas/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Logs (Anyone can write bugs/errors, only admin reads) ---
    match /bug_reports/{reportId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    match /error_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    match /system_logs/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }
    match /audit_logs/{logId} { 
      allow read: if isAdmin(); 
    }
    match /suspicious_activities/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- Other Collections ---
    match /reviews/{reviewId} { 
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(); 
    }
    match /support_tickets/{ticketId} { 
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); 
    }
    match /promotions/{promoId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
  }
}
