rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Validation ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 254 &&
             (data.name is string ? data.name.size() <= 100 : true) &&
             (data.role is string ? data.role == 'customer' || data.role == 'admin' : true);
    }
    
    function isValidProduct(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.price is number && data.price >= 0;
    }
    
    function isValidOrder(data) {
        return data.userId is string &&
               data.total is number && data.total >= 0 &&
               (data.status is string ? data.status.size() <= 50 : true);
    }

    // --- Match Rules ---

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin() && isValidUser(incoming());
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // Orders
    match /orders/{orderId} {
        allow read: if isOwner(resource.data.userId) || isAdmin();
        allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().userId == request.auth.uid;
        allow update: if (isOwner(resource.data.userId) || isAdmin()) && isValidOrder(incoming());
    }
  }
}
