{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "delivery"] },
        "wallet_balance": { "type": "number" },
        "khata_enabled": { "type": "boolean" },
        "khata_limit": { "type": "number" },
        "khata_balance": { "type": "number" },
        "credit_limit": { "type": "number" },
        "segment": { "type": "string" },
        "profile_photo": { "type": "string" },
        "street_address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip_code": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "order": {
        "title": "Order",
        "description": "Customer order",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "total": { "type": "number" },
            "status": { "type": "string" }
        },
        "required": ["userId", "total"]
    },
    "purchase_records": {
      "title": "Purchase Record",
      "description": "Log of purchase records from suppliers",
      "type": "object",
      "properties": {
        "supplier_details": { "type": "string" },
        "product_id": { "type": "string" },
        "quantity": { "type": "number" },
        "cost_price": { "type": "number" },
        "invoice_number": { "type": "string" },
        "batch_number": { "type": "string" },
        "expiry_date": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["product_id", "quantity", "cost_price"]
    }
  },
  "firestore": {
    "purchase_records/{orderId}": {
      "schema": "purchase_records",
      "description": "Purchase record logs"
    },    "users/{userId}": {
      "schema": "user",
      "description": "User profile collection"
    },
    "products/{productId}": {
        "schema": "product",
        "description": "Product catalog"
    },
    "orders/{orderId}": {
        "schema": "order",
        "description": "Customer orders"
    },
    "bug_reports/{reportId}": {
        "schema": "bug_report",
        "description": "System bug reports"
    },
    "suspicious_activities/{id}": {
        "schema": "suspicious_activity",
        "description": "Logs of suspicious security events"
    },
    "error_logs/{logId}": {
        "schema": "error_log",
        "description": "System error events and uncaught exceptions"
    },
    "system_logs/{id}": {
        "schema": "system_log",
        "description": "General system event logs"
    },
    "audit_logs/{id}": {
        "schema": "audit_log",
        "description": "Administrative audit trail"
    },
    "settings/{key}": {
        "schema": "setting",
        "description": "Global store settings"
    }
  }
}
